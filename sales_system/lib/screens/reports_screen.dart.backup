          ),
        );
      }
    } catch (e) {
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text('Error generating report: ${e.toString()}'),
            backgroundColor: Colors.red,
          ),
        );
      }
    }
  }

  void _generateProductReport() async {
    try {
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text('Generating Product Report PDF...'),
          backgroundColor: GlassLiquidTheme.accentBlue,
        ),
      );
      
      final reportsService = ReportsService();
      final pdfBytes = await reportsService.generateProductPerformanceReport();
      final filePath = await reportsService.saveReportToFile(pdfBytes, 'Product_Performance_Report');
      
