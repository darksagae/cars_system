  void _generateCollectionReport() async {
    try {
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text('Generating Payment Collection Report PDF...'),
          backgroundColor: GlassLiquidTheme.accentBlue,
        ),
      );
      
      final reportsService = ReportsService();
      final pdfBytes = await reportsService.generatePaymentCollectionReport();
      final filePath = await reportsService.saveReportToFile(pdfBytes, 'Payment_Collection_Report');
      
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
